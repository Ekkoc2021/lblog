<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.yang.lblogserver.blog.mapper.PostTagsMapper">

    <resultMap id="BaseResultMap" type="com.yang.lblogserver.blog.domain.PostTags">
            <id property="postId" column="post_id" />
            <id property="tagId" column="tag_id" />
    </resultMap>

    <sql id="Base_Column_List">
        post_id,tag_id
    </sql>

    <select id="selectByPostIds" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM post_tags
        WHERE post_id IN
        <foreach collection="list" item="postId" open="(" separator="," close=")">
            #{postId}
        </foreach>
    </select>

    <delete id="deleteByPostId">
        DELETE FROM post_tags WHERE post_id = #{postId}
    </delete>

    <insert id="insertBatch">
        INSERT INTO post_tags (post_id, tag_id) VALUES
        <foreach collection="list" item="item" separator=",">
            (#{item.postId}, #{item.tagId})
        </foreach>
    </insert>

</mapper>

<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.yang.lblogserver.blog.mapper.TagsMapper">

    <resultMap id="BaseResultMap" type="com.yang.lblogserver.blog.domain.Tags">
            <id property="id" column="id" />
            <result property="name" column="name" />
            <result property="slug" column="slug" />
            <result property="createdBy" column="created_by" />
            <result property="createdAt" column="created_at" />
            <result property="updatedAt" column="updated_at" />
            <result property="deletedAt" column="deleted_at" />
            <result property="isDelelte" column="is_delelte" />
    </resultMap>

    <sql id="Base_Column_List">
        id,name,slug,created_by,created_at,updated_at,
        deleted_at,is_delelte
    </sql>

    <resultMap id="TagWithCountMap" type="com.yang.lblogserver.blog.vo.TagVO">
        <id property="id" column="id" />
        <result property="name" column="name" />
        <result property="slug" column="slug" />
        <result property="postCount" column="post_count" />
    </resultMap>

    <select id="selectTagsWithCount" resultMap="TagWithCountMap">
        SELECT t.id, t.name, t.slug, COUNT(pt.post_id) AS post_count
        FROM tags t
        LEFT JOIN post_tags pt ON t.id = pt.tag_id
        LEFT JOIN posts p ON pt.post_id = p.id AND p.status = 1 AND p.is_delelte = 0 AND p.deleted_at IS NULL
        WHERE t.is_delelte = 0 AND t.deleted_at IS NULL
        <if test="createdBy != null">AND t.created_by = #{createdBy}</if>
        GROUP BY t.id
        ORDER BY post_count DESC, t.id ASC
        <if test="limit != null">LIMIT #{limit}</if>
    </select>

    <select id="selectBatchIds" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM tags
        WHERE id IN
        <foreach collection="list" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </select>

    <select id="selectById" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM tags
        WHERE id = #{id} AND is_delelte = 0
    </select>

    <insert id="insertTag" useGeneratedKeys="true" keyProperty="id" keyColumn="id">
        INSERT INTO tags (name, slug, created_by, created_at, updated_at, is_delelte)
        VALUES (#{name}, #{slug}, #{createdBy}, NOW(), NOW(), 0)
    </insert>

    <update id="updateTag">
        UPDATE tags
        <set>
            <if test="name != null">name = #{name},</if>
            <if test="slug != null">slug = #{slug},</if>
            updated_at = NOW()
        </set>
        WHERE id = #{id} AND is_delelte = 0
    </update>

    <select id="countBySlug" resultType="int">
        SELECT COUNT(1) FROM tags
        WHERE slug = #{slug} AND is_delelte = 0 AND deleted_at IS NULL
        <if test="excludeId != null">AND id != #{excludeId}</if>
    </select>

    <update id="softDeleteTag">
        UPDATE tags SET is_delelte = 1, deleted_at = NOW()
        WHERE id = #{id}
    </update>

</mapper>

<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.yang.lblogserver.auth.mapper.PdfFolderMapper">

    <resultMap id="BaseResultMap" type="com.yang.lblogserver.auth.domain.PdfFolder">
        <id property="id" column="id" />
        <result property="userId" column="user_id" />
        <result property="parentId" column="parent_id" />
        <result property="name" column="name" />
        <result property="sortOrder" column="sort_order" />
        <result property="createdAt" column="created_at" />
        <result property="updatedAt" column="updated_at" />
    </resultMap>

    <sql id="Base_Column_List">
        id, user_id, parent_id, name, sort_order, created_at, updated_at
    </sql>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id" keyColumn="id">
        INSERT INTO pdf_folders (user_id, parent_id, name, sort_order, created_at, updated_at)
        VALUES (#{userId}, #{parentId}, #{name}, #{sortOrder}, NOW(), NOW())
    </insert>

    <select id="selectById" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM pdf_folders
        WHERE id = #{id}
    </select>

    <select id="selectByUser" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM pdf_folders
        WHERE user_id = #{userId}
        ORDER BY sort_order ASC, created_at ASC
    </select>

    <update id="update">
        UPDATE pdf_folders
        SET name = #{name},
            parent_id = #{parentId}
        WHERE id = #{id}
    </update>

    <delete id="delete">
        DELETE FROM pdf_folders WHERE id = #{id}
    </delete>

</mapper>

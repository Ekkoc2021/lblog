<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.yang.lblogserver.ai.prompt.mapper.AiPromptAuditMapper">

    <resultMap id="BaseResultMap" type="com.yang.lblogserver.ai.prompt.domain.AiPromptAudit">
        <id column="id" property="id"/>
        <result column="prompt_id" property="promptId"/>
        <result column="module" property="module"/>
        <result column="prompt_key" property="promptKey"/>
        <result column="old_content" property="oldContent"/>
        <result column="new_content" property="newContent"/>
        <result column="old_version" property="oldVersion"/>
        <result column="new_version" property="newVersion"/>
        <result column="action" property="action"/>
        <result column="operator" property="operator"/>
        <result column="remark" property="remark"/>
        <result column="created_at" property="createdAt"/>
    </resultMap>

    <sql id="baseColumns">
        id, prompt_id, module, prompt_key,
        old_content, new_content, old_version, new_version,
        action, operator, remark, created_at
    </sql>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO ai_prompts_audit (prompt_id, module, prompt_key,
                                      old_content, new_content, old_version, new_version,
                                      action, operator, remark)
        VALUES (#{promptId}, #{module}, #{promptKey},
                #{oldContent}, #{newContent}, #{oldVersion}, #{newVersion},
                #{action}, #{operator}, #{remark})
    </insert>

    <select id="selectByPromptId" resultMap="BaseResultMap">
        SELECT <include refid="baseColumns"/>
        FROM ai_prompts_audit
        WHERE prompt_id = #{promptId}
        ORDER BY created_at DESC
    </select>

    <select id="selectByModuleAndKey" resultMap="BaseResultMap">
        SELECT <include refid="baseColumns"/>
        FROM ai_prompts_audit
        WHERE module = #{module} AND prompt_key = #{promptKey}
        ORDER BY created_at DESC
    </select>

</mapper>

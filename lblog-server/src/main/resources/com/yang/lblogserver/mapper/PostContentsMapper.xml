<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.yang.lblogserver.mapper.PostContentsMapper">

    <resultMap id="BaseResultMap" type="com.yang.lblogserver.domain.PostContents">
            <id property="id" column="id" />
            <result property="postId" column="post_id" />
            <result property="body" column="body" />
            <result property="format" column="format" />
            <result property="createdAt" column="created_at" />
            <result property="updatedAt" column="updated_at" />
            <result property="isDelelte" column="is_delelte" />
    </resultMap>

    <sql id="Base_Column_List">
        id,post_id,body,format,created_at,updated_at,
        is_delelte
    </sql>

    <select id="selectByPostId" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM post_contents
        WHERE post_id = #{postId} AND is_delelte = 0
        LIMIT 1
    </select>

</mapper>

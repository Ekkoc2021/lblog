<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.yang.lblogserver.mapper.CategoriesMapper">

    <resultMap id="BaseResultMap" type="com.yang.lblogserver.domain.Categories">
            <id property="id" column="id" />
            <result property="name" column="name" />
            <result property="slug" column="slug" />
            <result property="parentId" column="parent_id" />
            <result property="description" column="description" />
            <result property="sortOrder" column="sort_order" />
            <result property="createdBy" column="created_by" />
            <result property="createdAt" column="created_at" />
            <result property="updatedAt" column="updated_at" />
            <result property="deletedAt" column="deleted_at" />
            <result property="isDelelte" column="is_delelte" />
    </resultMap>

    <sql id="Base_Column_List">
        id,name,slug,parent_id,description,sort_order,
        created_by,created_at,updated_at,deleted_at,is_delelte
    </sql>

    <resultMap id="CategoryWithCountMap" type="com.yang.lblogserver.vo.CategoryVO">
        <id property="id" column="id" />
        <result property="name" column="name" />
        <result property="slug" column="slug" />
        <result property="parentId" column="parent_id" />
        <result property="description" column="description" />
        <result property="sortOrder" column="sort_order" />
        <result property="postCount" column="post_count" />
    </resultMap>

    <select id="selectCategoriesWithCount" resultMap="CategoryWithCountMap">
        SELECT c.id, c.name, c.slug, c.parent_id, c.description, c.sort_order,
               COUNT(p.id) AS post_count
        FROM categories c
        LEFT JOIN posts p ON c.id = p.category_id AND p.status = 1 AND p.is_delelte = 0 AND p.deleted_at IS NULL
        WHERE c.parent_id IS NULL AND c.is_delelte = 0 AND c.deleted_at IS NULL
        GROUP BY c.id, c.name, c.slug, c.parent_id, c.description, c.sort_order
        ORDER BY c.sort_order ASC
    </select>

    <select id="selectBatchIds" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM categories
        WHERE id IN
        <foreach collection="list" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </select>

</mapper>
